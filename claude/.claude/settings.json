{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(bin/rails:*)",
      "Bash(bin/standardrb:*)",
      "Bash(bundle:*)",
      "Bash(curl:*)",
      "Bash(fizzy:*)",
      "Bash(gh pr:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git ls-tree:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git worktree:*)",
      "Bash(just:*)",
      "Bash(mise x:*)",
      "Bash(npx playwright-cli:*)",
      "Bash(ruby:*)",
      "Bash(yarn:*)",
      "mcp__plugin_context7_context7__*",
      "Skill(fizzy)",
      "Skill(playwright-cli)",
      "WebSearch"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-main-branch.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": false,
    "superpowers@claude-plugins-official": false,
    "claude-code-wakatime@wakatime": true,
    "context7@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "superpowers-ruby@superpowers-ruby": true,
    "superpowers@superpowers-marketplace": false,
    "slack@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "superpowers-ruby": {
      "source": {
        "source": "github",
        "repo": "lucianghinda/superpowers-ruby"
      }
    }
  },
  "effortLevel": "high",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
